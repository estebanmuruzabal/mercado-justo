# =============================================================================
# PRODUCTION reference — Vercel "Production" scope
# =============================================================================
# These values are NOT loaded from a file in production. They document what to
# set in Vercel → Settings → Environment Variables with the **Production** scope.
# See docs/ENVIRONMENTS.md.
#
# Use the REAL Supabase project and the production bot. Keep these secrets out of
# git, Slack, screenshots, etc.
# =============================================================================

# ── Environment identity ──
NEXT_PUBLIC_APP_ENV=production

# ── Public site URL (HTTPS, no trailing slash) ──
NEXT_PUBLIC_SITE_URL=https://midominio.com

# ── Supabase (production project) ──
NEXT_PUBLIC_SUPABASE_URL=https://<prod-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<prod-anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<prod-service-role-key>


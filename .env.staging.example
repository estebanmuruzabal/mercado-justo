# =============================================================================
# STAGING reference — Vercel "Preview" scope
# =============================================================================
# These values are NOT loaded from a file in staging. They document what to set
# in Vercel → Settings → Environment Variables with the **Preview** scope
# (Preview deployments are treated as staging). See docs/ENVIRONMENTS.md.
#
# Use a SEPARATE Supabase project and the DEV/STAGING bot — never production's.
# =============================================================================

# ── Environment identity ──
NEXT_PUBLIC_APP_ENV=staging

# ── Public site URL (HTTPS, no trailing slash) ──
NEXT_PUBLIC_SITE_URL=https://staging.midominio.com

# ── Supabase (staging project) ──
NEXT_PUBLIC_SUPABASE_URL=https://<staging-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<staging-anon-or-publishable-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# Connection string for `npm run db:push:staging` (local CLI only — not used by Vercel).
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres
SUPABASE_STAGING_DB_URL=

# ── Telegram (DEV/STAGING bot: @MercadoJustoDevBot) ──
TELEGRAM_BOT_TOKEN=<dev-bot-token>
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=MercadoJustoDevBot
# Distinct from dev/production. Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=<staging-webhook-secret>

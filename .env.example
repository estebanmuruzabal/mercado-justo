# =============================================================================
# Mercado Justo — Environment template
# =============================================================================
# Copy this file to `.env.local` for LOCAL development:
#     cp .env.example .env.local
#
# Then fill the values. Get local Supabase keys with:
#     supabase start && supabase status -o env
#
# STAGING and PRODUCTION values are NOT stored in files — they are configured
# in the Vercel dashboard (Preview = staging, Production = production).
# See docs/ENVIRONMENTS.md for the full guide.
#
# Rule: never commit real secrets. This template ships with placeholders only.
# Public values are prefixed NEXT_PUBLIC_ and are exposed to the browser.
# =============================================================================

# ── Environment identity ─────────────────────────────────────────────────────
# development | staging | production
# On Vercel this is also derived from VERCEL_ENV, but set it explicitly so the
# client bundle knows the environment too.
NEXT_PUBLIC_APP_ENV=development

# ── Public site URL (single source of truth, no trailing slash) ──────────────
# Local default. For Telegram testing, expose localhost over HTTPS (ngrok /
# cloudflared) and put that URL here instead:
#   NEXT_PUBLIC_SITE_URL=https://xxxx.ngrok-free.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────────────────
# Local: `supabase start` → http://127.0.0.1:54321 + keys from `supabase status`.
# Staging/Production: use each project's URL + keys (set in Vercel).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ── Telegram bot (one bot PER environment) ───────────────────────────────────
# development/staging → @MercadoJustoDevBot   production → @MercadoJustoBot
# TELEGRAM_BOT_TOKEN is a SERVER SECRET — never expose it client-side.
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=MercadoJustoDevBot
# Long random string validated on every inbound webhook request.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=generate-a-long-random-string

{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/check-env.js && node scripts/generate-build-info.js",
    "dev": "next dev --turbo",
    "prebuild": "node scripts/check-env.js && node scripts/generate-build-info.js",
    "build": "next build",
    "preprod": "node scripts/check-env.js --env-file .env.production",
    "prod": "node scripts/run-prod.js",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:seed": "node scripts/db-seed.js",
    "db:seed:staging": "node scripts/db-seed-staging.js",
    "db:setup": "node scripts/db-setup.js",
    "db:types": "supabase gen types --local > types/supabase.ts",
    "db:push": "supabase db push",
    "db:push:staging": "node scripts/db-push-staging.js",
    "env:check": "node scripts/check-env.js",
    "dev:tunnel": "ngrok http 3000",
    "dev:tunnel:cf": "cloudflared tunnel --url http://localhost:3000",
    "telegram:webhook:set": "node scripts/telegram-set-webhook.js",
    "telegram:webhook:info": "node scripts/telegram-set-webhook.js --info",
    "telegram:webhook:delete": "node scripts/telegram-set-webhook.js --delete",
    "email:dev": "email dev --dir emails",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.12",
    "@react-email/components": "^1.0.12",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.104.0",
    "@types/leaflet": "^1.9.21",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.40.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^0.511.0",
    "next": "15.5.18",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-email": "^6.5.0",
    "react-hook-form": "^7.56.4",
    "react-leaflet": "^5.0.0",
    "resend": "^6.12.4",
    "sonner": "^2.0.4",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.42",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^20.17.57",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "eslint-config-prettier": "^10.1.5",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.0",
    "prettier": "^3.5.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.1.4"
  }
}
